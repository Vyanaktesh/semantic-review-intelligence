{
  "name": "semantic-review-intelligence",
  "private": true,
  "version": "2.0.0",
  "description": "SRIS — Semantic Review Intelligence System (root workspace runner)",
  "scripts": {
    "dev": "concurrently --names \"server,frontend\" --prefix-colors \"cyan,magenta\" \"npm:dev:server\" \"npm:dev:frontend\"",
    "dev:server": "npm --prefix server run dev",
    "dev:frontend": "npm --prefix frontend run dev",
    "start": "npm --prefix server start",
    "build": "npm --prefix frontend run build",
    "install:all": "npm install && npm --prefix server install && npm --prefix frontend install",
    "test:db": "node server/test-connection.mjs"
  },
  "devDependencies": {
    "concurrently": "^9.1.0"
  }
}
